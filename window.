/* ─── HELPERS ────────────────────────────────────────────────────────── */
function courseById(id){ return COURSES.find(c=>c.id===id); }
function roundById(id){ const s=getStore(); return s.rounds.find(r=>r.id===id); }
function sortedRounds(){ return [...getStore().rounds].sort((a,b)=>b.date.localeCompare(a.date)); }

function avg(arr){ const f=arr.filter(v=>v!=null&&!isNaN(v)); return f.length?f.reduce((s,v)=>s+v,0)/f.length:0; }
function pct(n,d){ return d?Math.round(100*n/d):0; }

function roundTotals(round){
  const c = courseById(round.courseId);
  const pars = c.holes;
  const total = round.holes.reduce((s,h)=>s+(h.score||0),0);
  const par = pars.reduce((s,p)=>s+p,0);
  const putts = round.holes.reduce((s,h)=>s+h.putts,0);
  const penalties = round.holes.reduce((s,h)=>s+(h.penalties||0),0);
  const firOpp = pars.filter(p=>p>3).length;
  const firHit = round.holes.filter((h,i)=>pars[i]>3 && h.fir==='yes').length;
  const girHit = round.holes.filter(h=>h.gir==='yes'||h.gir==='chip').length;
  return { total, par, putts, penalties, firHit, firOpp, girHit, girOpp:18, course:c };
}

function relStr(score, par){
  const d = score - par;
  if(d <= -2) return 'Eagle';
  if(d === -1) return 'Birdie';
  if(d === 0) return 'E';
  if(d === 1) return '+1 Bogey';
  if(d === 2) return '+2 Dbl';
  return `+${d}`;
}
function relClass(score, par){
  const d = score - par;
  if(d <= -2) return 'td-eagle';
  if(d === -1) return 'td-birdie';
  if(d === 1) return 'td-bogey';
  if(d >= 2) return 'td-dbl';
  return '';
}

function scorePill(total, avg){
  if(!avg) return `<span class="pill pill-neu">${total}</span>`;
  if(total <= avg-1) return `<span class="pill pill-good">${total}</span>`;
  if(total <= avg+1) return `<span class="pill pill-warn">${total}</span>`;
  return `<span class="pill pill-bad">${total}</span>`;
}

function statBox(label, value, foot=''){
  return `<div class="stat-box">
    <div class="stat-label">${label}</div>
    <div class="stat-value">${value}</div>
    ${foot?`<div class="stat-foot">${foot}</div>`:''}
  </div>`;
}

function emptyHole(par){
  return { score:par, putts:2, penalties:0, fir:par>3?'yes':'na', gir:'yes', firstPuttDist:3 };
}

function todayStr(){ return new Date().toISOString().slice(0,10); }

function scoreBuckets(round){
  const c = courseById(round.courseId);
  let eagles=0, birdies=0, pars=0, bogeys=0, doubles=0, worse=0;
  round.holes.forEach((h,i)=>{
    const d=h.score-c.holes[i];
    if(d<=-2) eagles++;
    else if(d===-1) birdies++;
    else if(d===0) pars++;
    else if(d===1) bogeys++;
    else if(d===2) doubles++;
    else worse++;
  });
  return {eagles,birdies,pars,bogeys,doubles,worse};
}

