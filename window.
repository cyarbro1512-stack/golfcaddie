      } else {
        showNewRoundSheet();
      }
      return;
    }
    showView(nav);
  });

  // Theme toggle
  const html = document.documentElement;
  const sunIcon = document.getElementById('themeIconSun');
  const moonIcon = document.getElementById('themeIconMoon');
  function applyTheme(dark){
    html.setAttribute('data-theme', dark?'dark':'light');
    sunIcon.classList.toggle('hidden', dark);
    moonIcon.classList.toggle('hidden', !dark);
    // Redraw chart
    if(state.chart){ renderDashboard(); }
  }
  const prefersDark = matchMedia('(prefers-color-scheme:dark)').matches;
  applyTheme(prefersDark);
  document.getElementById('themeBtn').onclick=()=>{
    const isDark = html.getAttribute('data-theme')==='dark';
    applyTheme(!isDark);
  };

  // Back buttons
  document.getElementById('backFromCourseDetail').onclick=()=>{ renderCourses(); showView('courses'); };
  document.getElementById('backFromSummary').onclick=()=>{
    showView(state.summaryFromView || 'rounds');
    if(state.summaryFromView==='rounds') renderRounds();
  };

  // New round buttons
  document.getElementById('newRoundBtn').onclick=()=>showNewRoundSheet();
  document.getElementById('newRoundFromRoundsBtn').onclick=()=>showNewRoundSheet();

  // Hole entry — steppers
  function bindStepper(minusId, plusId, valId, min, max, onchange){
    document.getElementById(minusId).addEventListener('click',()=>{
      const el = document.getElementById(valId);
      const v = Math.max(min, parseInt(el.textContent)-1);
      el.textContent = v;
      if(onchange) onchange(v);
    });
    document.getElementById(plusId).addEventListener('click',()=>{
      const el = document.getElementById(valId);
      const v = Math.min(max, parseInt(el.textContent)+1);
      el.textContent = v;
      if(onchange) onchange(v);
    });
  }
  // Score stepper — handles null (blank) state
  ['scoreMinus','scorePlus'].forEach(id=>{
    document.getElementById(id).addEventListener('click',()=>{
      const round = roundById(state.entryRoundId);
      if(!round) return;
      const par = courseById(round.courseId).holes[state.entryHole];
      const el = document.getElementById('scoreVal');
      const dir = id==='scorePlus' ? 1 : -1;
      const current = el.textContent === '—' ? null : parseInt(el.textContent);
      const next = Math.max(1, Math.min(15, current == null ? par + dir : current + dir));
      el.textContent = next;
      el.style.color = '';
      updateScoreRel(next, par);
    });
  });
  bindStepper('puttsMinus','puttsPLus','puttsVal',0,9,updatePuttsSub);
  bindStepper('penMinus','penPlus','penVal',0,9);


  // Segment buttons (FIR/GIR)
  document.querySelectorAll('.seg-btn').forEach(btn=>{
    btn.addEventListener('click',()=>{
      const key = btn.dataset.key;
      document.querySelectorAll(`[data-key="${key}"]`).forEach(b=>b.classList.remove('active','active-good','active-warn'));
      btn.classList.add('active');
      if(key === 'fpd'){
        btn.classList.add('active-warn');
      } else if(btn.dataset.val==='yes'){
        btn.classList.add('active-good');
      } else if(btn.dataset.val !== 'na'){
        btn.classList.add('active-warn');
      }
    });
  });

  // Hole navigation
  document.getElementById('prevHoleBtn').onclick=()=>{
    saveCurrentHole();
    state.entryHole = Math.max(0, state.entryHole-1);
    populateEntry();
  };
  document.getElementById('nextHoleBtn').onclick=()=>{
    saveCurrentHole();
    state.entryHole = Math.min(17, state.entryHole+1);
    populateEntry();
    window.scrollTo({top:0,behavior:'smooth'});
    document.getElementById('mainContent').scrollTo({top:0,behavior:'smooth'});
  };

  document.getElementById('nextHoleBottomBtn').onclick=()=>{
    saveCurrentHole();
    if(state.entryHole < 17){
      state.entryHole++;
      populateEntry();
    }
    window.scrollTo({top:0,behavior:'smooth'});
    document.getElementById('mainContent').scrollTo({top:0,behavior:'smooth'});
  };

  document.getElementById('saveDraftBtn').onclick=()=>{
    saveCurrentHole();
    const round = roundById(state.entryRoundId);
    if(round){ round.status='in-progress'; const s=getStore(); const i=s.rounds.findIndex(r=>r.id===round.id); if(i>=0){s.rounds[i]=round;saveStore(s);} }
    renderAll();
    showView('rounds');
  };

  document.getElementById('finishRoundBtn').onclick=()=>{
    saveCurrentHole();
    const round = roundById(state.entryRoundId);
    if(!round) return;
    const missing = round.holes.map((h,i)=>h.score==null?i+1:null).filter(n=>n!==null);
    if(missing.length > 0){
      const holeList = missing.join(', ');
      const proceed = confirm(`Scores missing on hole${missing.length>1?'s':''} ${holeList}. Finish anyway?`);
      if(!proceed) return;
    }
    openRoundSummary(state.entryRoundId, 'entry');
  };

  // DEV: fill all 18 holes with realistic data
  document.getElementById('devFillBtn').onclick=()=>{
    saveCurrentHole();
    const round = roundById(state.entryRoundId);
    if(!round) return;
    const course = courseById(round.courseId);
    const fpdOptions = [3,5,10,15,20,30,40,50];
    course.holes.forEach((par,i)=>{
      const isP3 = par === 3;
      const offset = [0,0,0,1,1,1,1,2,-1][Math.floor(Math.random()*9)];
      const score = Math.max(1, par + offset);
      const gir = offset <= 0 ? 'yes' : (['short','long','left','right'][Math.floor(Math.random()*4)]);
      const fir = isP3 ? 'na' : (Math.random()<.55 ? 'yes' : (['left','right','short','long'][Math.floor(Math.random()*4)]));
      const putts = gir==='yes' ? (Math.random()<.4?1:2) : (score<=par?1:2+(Math.random()<.15?1:0));
      const fpd = gir==='yes' ? fpdOptions[Math.floor(Math.random()*4)] : fpdOptions[4+Math.floor(Math.random()*4)];
      round.holes[i] = { score, putts, penalties: Math.random()<.08?1:0, fir, gir, firstPuttDist: fpd };
    });
    const s = getStore();
    const idx = s.rounds.findIndex(r=>r.id===round.id);
    if(idx>=0){ s.rounds[idx]=round; saveStore(s); }
    // go back to hole 1 to show filled data
    state.entryHole = 0;
    populateEntry();
    window.scrollTo({top:0,behavior:'smooth'});
    document.getElementById('mainContent').scrollTo({top:0,behavior:'smooth'});
  };

  document.getElementById('openScorecardBtn').onclick=async ()=>{
    saveCurrentHole();
    const round = roundById(state.entryRoundId);
    if(round) await saveRoundToSupabase(round);
    openRoundSummary(state.entryRoundId,'entry');
  };

  // Summary actions
  document.getElementById('summaryEditBtn').onclick=()=>{
    state.entryRoundId = state.selectedRoundId;
    state.entryHole = 0;
    populateEntry();
    showView('entry');
  };
  document.getElementById('summaryCompleteBtn').onclick=async ()=>{
    const s = getStore();
    const idx = s.rounds.findIndex(r=>r.id===state.selectedRoundId);
    if(idx<0) return;
    s.rounds[idx].status='complete';
    saveStore(s);
    const ok = await saveRoundToSupabase(s.rounds[idx]);
    if(!ok) return;
    renderAll();
    renderSummary();
  };

  // Rounds filter chips
  document.querySelectorAll('[data-filter]').forEach(btn=>btn.onclick=()=>{
    state.roundsFilter = btn.dataset.filter;
    document.querySelectorAll('[data-filter]').forEach(b=>b.classList.toggle('active-filter', b===btn));
    renderRounds();
  });
  document.getElementById('sortDateBtn').onclick=()=>{
    state.roundsSort='date'; renderRounds();
  };
  document.getElementById('sortCourseBtn').onclick=()=>{
    state.roundsSort='course'; renderRounds();
  };

  // Performance baseline selector
  document.querySelectorAll('[data-baseline]').forEach(btn=>{
    btn.onclick=()=>{
      _sgBaseline = btn.dataset.baseline;
      document.querySelectorAll('[data-baseline]').forEach(b=>b.classList.toggle('active-filter', b===btn));
      renderPerformance();
    };
  });

  // Club distances accordion
  document.getElementById('clubAccordionBtn').onclick=()=>{
    const btn = document.getElementById('clubAccordionBtn');
    const body = document.getElementById('clubAccordionBody');
    btn.classList.toggle('open');
    body.classList.toggle('open');
  };

  // Save clubs
  document.getElementById('saveClubsBtn').onclick=()=>{
    const s = getStore();
    document.querySelectorAll('[data-club-idx]').forEach(input=>{
      const i = parseInt(input.dataset.clubIdx);
      s.clubs[i].carry = parseInt(input.value)||0;
    });
    saveStore(s);
    renderClubDisplay();
    // flash button
    const btn = document.getElementById('saveClubsBtn');
    btn.textContent = '✓ Saved';
    setTimeout(()=>btn.textContent='Save', 1500);
  };

  // Schema accordion
  document.getElementById('schemaToggle').onclick=()=>{
    const btn = document.getElementById('schemaToggle');
    const body = document.getElementById('schemaBody');
    btn.classList.toggle('open');
    body.classList.toggle('open');
  };
}

// Active filter style
const style = document.createElement('style');
style.textContent = `.active-filter{background:var(--primary)!important;color:var(--inv)!important;border-color:transparent!important}`;
document.head.appendChild(style);

/* ─── INIT ─────────────────────────────────────────────────────────── */
bindUI();
showView('dashboard');
initSupabaseStore();
</script>
</body>
</html>
