// Override startNewRound to accept date
async function startNewRound(courseId, date){
  const cid = courseId || COURSES[0].id;
  const course = courseById(cid);
  const round = {
    id: 'r' + Date.now(),
    courseId: cid,
    date: date || todayStr(),
    tee: course.tee,
    notes: '',
    status: 'in-progress',
    holes: course.holes.map(emptyHole)
  };
  const s = getStore();
  s.rounds.unshift(round);
  saveStore(s);
  const ok = await saveRoundToSupabase(round);
  if(!ok) return;
  state.entryRoundId = round.id;
  state.entryHole = 0;
  populateEntry();
  showView('entry');
}

