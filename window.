/* ─── COURSES ────────────────────────────────────────────────────────── */
function courseAnalytics(courseId){
  const rounds = sortedRounds().filter(r=>r.courseId===courseId && r.status==='complete');
  const course = courseById(courseId);
  const sums = rounds.map(roundTotals);
  const holeStats = course.holes.map((par,i)=>{
    const hs = rounds.map(r=>r.holes[i]);
    const avgS = avg(hs.map(h=>h.score));
    const firPct2 = par>3 ? pct(hs.filter(h=>h.fir==='yes').length,hs.length) : null;
    return { hole:i+1, par, avgScore:avgS, best:hs.length?Math.min(...hs.map(h=>h.score)):0, avgPutts:avg(hs.map(h=>h.putts)), girPct:pct(hs.filter(h=>h.gir==='yes'||h.gir==='chip').length,hs.length), firPct:firPct2, diff:avgS-par };
  });
  return {
    course, rounds, holeStats,
    avgScore: avg(sums.map(s=>s.total)),
    bestScore: sums.length?Math.min(...sums.map(s=>s.total)):0,
    worstScore: sums.length?Math.max(...sums.map(s=>s.total)):0,
    avgPutts: avg(sums.map(s=>s.putts)),
    firPct: pct(sums.reduce((a,s)=>a+s.firHit,0),sums.reduce((a,s)=>a+s.firOpp,0)),
    girPct: pct(sums.reduce((a,s)=>a+s.girHit,0),sums.reduce((a,s)=>a+s.girOpp,0)),
  };
}

