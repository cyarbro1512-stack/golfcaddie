function renderDashboard(){
  const completed = sortedRounds().filter(r=>r.status==='complete');
  const sums = completed.map(roundTotals);
  const avgScore = avg(sums.map(s=>s.total));
  const avgPutts = avg(sums.map(s=>s.putts));
  const firPct = pct(sums.reduce((a,s)=>a+s.firHit,0), sums.reduce((a,s)=>a+s.firOpp,0));
  const girPct = pct(sums.reduce((a,s)=>a+s.girHit,0), sums.reduce((a,s)=>a+s.girOpp,0));

  const badge = document.getElementById('dashBadge');
  badge.textContent = completed.length ? `${completed.length} completed round${completed.length>1?'s':''}` : 'No completed rounds yet';

  document.getElementById('dashStats').innerHTML = [
    statBox('Avg Score', avgScore?avgScore.toFixed(1):'—', 'All rounds'),
    statBox('FIR %', `${firPct}%`, 'Fairways hit'),
    statBox('GIR %', `${girPct}%`, 'Greens hit'),
    statBox('Avg Putts', avgPutts?avgPutts.toFixed(1):'—', 'Per round'),
  ].join('');

  // Active round banner
  const inProgress = sortedRounds().find(r=>r.status==='in-progress');
  const banner = document.getElementById('activeRoundBanner');
  if(inProgress){
    banner.classList.remove('hidden');
    const c = courseById(inProgress.courseId);
    document.getElementById('activeRoundText').textContent = `Active round · ${c.name} · ${inProgress.date}`;
    document.getElementById('resumeActiveBtn').onclick = ()=>{
      state.entryRoundId = inProgress.id;
      state.entryHole = inProgress.holes.findIndex(h=>h.score===courseById(inProgress.courseId).holes[0])||0;
      populateEntry();
      showView('entry');
    };
  } else {
    banner.classList.add('hidden');
  }

  // Recent rounds
  const recent = sortedRounds().slice(0,5);
  const listEl = document.getElementById('recentRoundsList');
  if(recent.length){
    listEl.innerHTML = `<div class="section-hd"><h2>Recent Rounds</h2></div>` +
      recent.map(r=>{
        const t = roundTotals(r);
        const statusPill = r.status==='complete'
          ? `<span class="pill pill-good">Completed</span>`
          : `<span class="pill pill-warn">Draft</span>`;
        return `<div class="list-item" data-round="${r.id}">
          <div class="list-row">
            <strong>${t.course.name}</strong>
            ${statusPill}
          </div>
          <div class="list-sub">${r.date} · Score ${t.total} · Putts ${t.putts}</div>
          <div style="display:flex;gap:.5rem;margin-top:.1rem">
            <button class="btn btn-secondary btn-sm" data-view-round="${r.id}">View</button>
            ${r.status!=='complete'?`<button class="btn btn-primary btn-sm" data-resume-round="${r.id}">Resume</button>`:''}
          </div>
        </div>`;
      }).join('');
  } else {
    listEl.innerHTML = `<div class="section-hd"><h2>Recent Rounds</h2></div><div class="empty-state">No rounds yet.<br>Tap Entry to start your first round.</div>`;
  }

  // Bind recent round buttons
  listEl.querySelectorAll('[data-view-round]').forEach(b=>b.onclick=(e)=>{ e.stopPropagation(); openRoundSummary(b.dataset.viewRound, 'dashboard'); });
  listEl.querySelectorAll('[data-resume-round]').forEach(b=>b.onclick=(e)=>{ e.stopPropagation(); resumeRound(b.dataset.resumeRound); });
  listEl.querySelectorAll('.list-item[data-round]').forEach(item=>item.onclick=()=>openRoundSummary(item.dataset.round, 'dashboard'));

  document.getElementById('trendLabel').textContent = `Last ${Math.min(completed.length,12)} rounds`;
  renderTrendChart(completed);
}

function renderTrendChart(rounds){
  const ctx = document.getElementById('trendChart').getContext('2d');
  const recent = rounds.slice(0,12).reverse();
  const labels = recent.map(r=>r.date.slice(5));
  const scores = recent.map(r=>roundTotals(r).total);
  const rolling = scores.map((_,i)=>+(avg(scores.slice(Math.max(0,i-2),i+1)).toFixed(1)));

  const cssVar = v => getComputedStyle(document.documentElement).getPropertyValue(v).trim();

  if(state.chart){ state.chart.destroy(); state.chart=null; }

  if(!scores.length){
    ctx.clearRect(0,0,ctx.canvas.width,ctx.canvas.height);
    ctx.fillStyle = cssVar('--faint');
    ctx.font = '14px Satoshi, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('No completed rounds yet', ctx.canvas.width/2, 95);
    return;
  }

  state.chart = new Chart(ctx, {
    type:'line',
    data:{
      labels,
      datasets:[
        { label:'Score', data:scores, borderColor:cssVar('--primary'), borderWidth:2.5, tension:.35, pointBackgroundColor:cssVar('--primary'), pointRadius:4, fill:false },
