function normalizeHoleRow(found, par){
  return found ? {
    score: found.score ?? null,
    putts: found.putts ?? 0,
    penalties: found.penalties ?? 0,
    fir: found.fir ?? (par > 3 ? 'yes' : 'na'),
    gir: found.gir ?? 'yes',
    firstPuttDist: found.first_putt_dist ?? 3
  } : emptyHole(par);
}

function normalizeRound(row, holes){
  const course = courseById(row.course_id) || { holes: Array(18).fill(4) };
  return {
    id: row.id,
    courseId: row.course_id,
    date: row.date,
    tee: row.tee || '',
    notes: row.notes || '',
    status: row.status === 'in_progress' ? 'in-progress' : row.status,
    holes: Array.from({length:18}, (_, i) => {
      const found = holes.find(h => Number(h.hole_number) === i + 1);
      return normalizeHoleRow(found, course.holes[i]);
    })
  };
}

async function loadRoundsFromSupabase(){
  const { data: roundRows, error: roundsError } = await sp
    .from('rounds')
    .select('*')
    .eq('profile_key', PROFILE_KEY)
    .order('date', { ascending: false });
  if(roundsError){
    console.error('Error loading rounds:', roundsError);
    alert('Could not load rounds from Supabase.');
    return [];
  }

  const { data: holeRows, error: holesError } = await sb
    .from('round_holes')
    .select('*')
    .eq('profile_key', PROFILE_KEY);
  if(holesError){
    console.error('Error loading round holes:', holesError);
    alert('Could not load hole data from Supabase.');
    return [];
  }

  return roundRows.map(r => normalizeRound(r, holeRows.filter(h => h.round_id === r.id)));
}

async function saveRoundToSupabase(round){
  const payload = {
    id: round.id,
    profile_key: PROFILE_KEY,
    course_id: round.courseId,
    date: round.date,
    tee: round.tee || '',
    notes: round.notes || '',
    status: round.status === 'in-progress' ? 'in_progress' : 'complete'
  };

  const { error: roundError } = await sb.from('rounds').upsert(payload);
  if(roundError){
    console.error('Error saving round:', roundError);
    alert('Could not save round to Supabase.');
    return false;
  }

  const { error: deleteError } = await sb
    .from('round_holes')
    .delete()
    .eq('round_id', round.id)
    .eq('profile_key', PROFILE_KEY);
  if(deleteError){
    console.error('Error clearing round holes:', deleteError);
    alert('Could not clear prior hole data.');
    return false;
  }

  const holePayload = round.holes.map((h, idx) => ({
    round_id: round.id,
    profile_key: PROFILE_KEY,
    hole_number: idx + 1,
    score: h.score ?? null,
    putts: Number(h.putts ?? 0),
    penalties: Number(h.penalties ?? 0),
    fir: h.fir ?? 'na',
    gir: h.gir ?? 'yes',
    first_putt_dist: Number(h.firstPuttDist ?? 3)
  }));

  const { error: holesError } = await sb.from('round_holes').insert(holePayload);
  if(holesError){
    console.error('Error saving round holes:', holesError);
    alert('Could not save hole data to Supabase.');
    return false;
  }

  return true;
}

