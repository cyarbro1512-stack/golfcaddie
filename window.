<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <title>The Stat Caddie</title>
  <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
  <link href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,600,700&display=swap" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
/* ─── TOKENS ─────────────────────────────────────────────────────────── */
:root {
  --bg:        #f4f2ee;
  --surface:   #faf9f7;
  --surface2:  #f0ede8;
  --border:    rgba(40,36,28,.12);
  --divider:   rgba(40,36,28,.08);
  --text:      #1e1c17;
  --muted:     #6b6760;
  --faint:     #a09d97;
  --inv:       #fdf9f4;
  --primary:   #136b60;
  --primary-h: #0a4f46;
  --primary-l: rgba(19,107,96,.12);
  --accent:    #b47c16;
  --good:      #3a7a1e;
  --good-bg:   rgba(58,122,30,.12);
  --warn:      #946210;
  --warn-bg:   rgba(148,98,16,.12);
  --bad:       #9e2f3c;
  --bad-bg:    rgba(158,47,60,.12);
  --r-sm:      .5rem;
  --r-md:      .875rem;
  --r-lg:      1.25rem;
  --r-full:    9999px;
  --sh-sm:     0 1px 3px rgba(0,0,0,.07);
  --sh-md:     0 6px 20px rgba(0,0,0,.09);
  --nav-h:     72px;
}
[data-theme="dark"] {
  --bg:        #151410;
  --surface:   #1b1a16;
  --surface2:  #211f1b;
  --border:    rgba(255,255,255,.09);
  --divider:   rgba(255,255,255,.06);
  --text:      #e4e0d8;
  --muted:     #a09d97;
  --faint:     #6b6860;
  --inv:       #1b1a16;
  --primary:   #3fa895;
  --primary-h: #4bbba7;
  --primary-l: rgba(63,168,149,.15);
  --accent:    #d4970d;
  --good:      #5aaa30;
  --good-bg:   rgba(90,170,48,.14);
  --warn:      #d4970d;
  --warn-bg:   rgba(212,151,13,.14);
  --bad:       #d95f6e;
  --bad-bg:    rgba(217,95,110,.14);
  --sh-sm:     0 1px 4px rgba(0,0,0,.3);
  --sh-md:     0 8px 28px rgba(0,0,0,.4);
}

/* ─── RESET ─────────────────────────────────────────────────────────── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html{scroll-behavior:smooth}
body{font-family:'Satoshi',system-ui,sans-serif;font-size:1rem;background:var(--bg);color:var(--text);min-height:100dvh;overflow-x:hidden;-webkit-font-smoothing:antialiased}
button,input,select,textarea{font:inherit;color:inherit;border:none;background:none;cursor:pointer}
img,svg{display:block}
a{color:inherit;text-decoration:none}

/* ─── LAYOUT ─────────────────────────────────────────────────────────── */
#app{display:flex;flex-direction:column;min-height:100dvh;max-width:480px;margin:0 auto}
.topbar{position:sticky;top:0;z-index:30;padding:.9rem 1rem .7rem;background:color-mix(in oklab,var(--bg) 90%, transparent);backdrop-filter:blur(20px) saturate(1.4);-webkit-backdrop-filter:blur(20px) saturate(1.4);border-bottom:1px solid var(--divider);display:flex;justify-content:space-between;align-items:center;gap:.75rem}
.topbar-brand{display:flex;align-items:center;gap:.75rem}
.logo-wrap{width:38px;height:38px;border-radius:12px;background:var(--primary);display:grid;place-items:center;color:var(--inv);flex-shrink:0}
.logo-wrap svg{width:22px;height:22px}
.topbar-title{font-size:1.05rem;font-weight:700;line-height:1.1}
.topbar-sub{font-size:.75rem;color:var(--muted);margin-top:.05rem}
.icon-btn{width:44px;height:44px;border-radius:14px;background:var(--surface);border:1px solid var(--border);display:grid;place-items:center;color:var(--muted);flex-shrink:0}

.main{flex:1;padding:1rem 1rem calc(var(--nav-h) + env(safe-area-inset-bottom) + 1.25rem);display:flex;flex-direction:column;gap:1rem}
.view{display:none;flex-direction:column;gap:1rem}
.view.active{display:flex}

/* ─── NAV ─────────────────────────────────────────────────────────── */
.nav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:min(480px,100%);height:calc(var(--nav-h) + env(safe-area-inset-bottom));padding:.5rem .75rem env(safe-area-inset-bottom);background:color-mix(in oklab,var(--bg) 92%, transparent);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-top:1px solid var(--divider);display:grid;grid-template-columns:repeat(5,1fr);gap:.25rem;z-index:30}
.nav-btn{border-radius:14px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.2rem;font-size:.6rem;font-weight:600;letter-spacing:.03em;color:var(--muted);padding:.3rem .2rem;transition:all .18s ease}
.nav-btn svg{width:22px;height:22px;stroke-width:1.8}
.nav-btn.active{background:var(--primary);color:var(--inv)}
.nav-btn.active svg{stroke-width:2.3}

/* ─── CARDS ─────────────────────────────────────────────────────────── */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);padding:1rem;box-shadow:var(--sh-sm)}
.card-hero{background:linear-gradient(160deg,color-mix(in oklab,var(--primary) 14%, var(--surface)) 0%, var(--surface) 55%)}
.section-hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:.6rem}
.section-hd h2{font-size:.75rem;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);font-weight:700}

/* ─── STATS GRID ─────────────────────────────────────────────────────── */
.stat-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:.6rem}
.stat-grid.cols3{grid-template-columns:repeat(3,1fr)}
.stat-grid.cols4{grid-template-columns:repeat(2,1fr)}
.stat-box{padding:.65rem .75rem;background:var(--surface2);border:1px solid var(--border);border-radius:var(--r-md)}
.stat-label{font-size:.65rem;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);font-weight:600}
.stat-value{font-size:1.35rem;font-weight:700;font-variant-numeric:tabular-nums lining-nums;margin-top:.15rem;line-height:1}
.stat-foot{font-size:.65rem;color:var(--faint);margin-top:.15rem}

/* ─── PILLS ─────────────────────────────────────────────────────────── */
.pill{display:inline-flex;align-items:center;padding:.2rem .55rem;border-radius:var(--r-full);font-size:.7rem;font-weight:700;line-height:1.4}
.pill-good{background:var(--good-bg);color:var(--good)}
.pill-warn{background:var(--warn-bg);color:var(--warn)}
.pill-bad{background:var(--bad-bg);color:var(--bad)}
.pill-neu{background:var(--surface2);color:var(--muted)}

/* ─── LIST ITEMS ─────────────────────────────────────────────────────── */
.list-item{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);padding:1rem;box-shadow:var(--sh-sm);display:flex;flex-direction:column;gap:.45rem;cursor:pointer;-webkit-user-select:none;user-select:none;transition:opacity .12s}
.list-item:active{opacity:.75}
.list-row{display:flex;justify-content:space-between;align-items:center;gap:.5rem}
.list-sub{font-size:.8rem;color:var(--muted)}

/* ─── BUTTONS ─────────────────────────────────────────────────────────── */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:.4rem;min-height:50px;padding:.75rem 1.1rem;border-radius:var(--r-md);font-weight:700;font-size:.95rem;transition:opacity .12s,transform .08s;-webkit-user-select:none;user-select:none}
.btn:active{opacity:.8;transform:scale(.98)}
.btn-primary{background:var(--primary);color:var(--inv)}
.btn-secondary{background:var(--surface2);border:1px solid var(--border);color:var(--text)}
.btn-outline{background:transparent;border:1.5px solid var(--primary);color:var(--primary)}
.btn-danger{background:var(--bad-bg);color:var(--bad);border:1px solid rgba(158,47,60,.2)}
.btn-sm{min-height:40px;padding:.5rem .85rem;font-size:.85rem;border-radius:var(--r-sm)}
.btn-full{width:100%}
.btn-row{display:grid;grid-template-columns:1fr 1fr;gap:.65rem}
.btn-row.cols3{grid-template-columns:1fr 1fr 1fr}

/* ─── FORM ─────────────────────────────────────────────────────────── */
.field{display:flex;flex-direction:column;gap:.35rem}
.field label{font-size:.8rem;font-weight:600}
.field input,.field select,.field textarea{min-height:48px;border-radius:var(--r-md);border:1.5px solid var(--border);background:var(--surface2);padding:.7rem .9rem;font-size:.95rem;outline:none;transition:border-color .15s}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--primary)}

/* ─── HOLE ENTRY ─────────────────────────────────────────────────────── */
.hole-header{background:var(--primary);color:var(--inv);border-radius:var(--r-lg);padding:1rem;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:.5rem}
.hole-hd-center{text-align:center}
.hole-num{font-size:2rem;font-weight:700;line-height:1;font-variant-numeric:tabular-nums}
.hole-par-label{font-size:.7rem;opacity:.7;margin-top:.1rem}
.hole-nav-btn{width:48px;height:48px;border-radius:var(--r-md);background:rgba(255,255,255,.18);display:grid;place-items:center;color:var(--inv);-webkit-user-select:none;user-select:none;transition:background .1s}
.hole-nav-btn:active{background:rgba(255,255,255,.3)}
.hole-nav-btn:disabled{opacity:.3}
.hole-nav-btn svg{width:24px;height:24px;stroke-width:2.5}
.hole-progress{display:grid;grid-template-columns:repeat(18,1fr);gap:.2rem;margin-top:.75rem}
.hole-dot{height:4px;border-radius:2px;background:rgba(255,255,255,.25);transition:background .2s}
.hole-dot.filled{background:rgba(255,255,255,.9)}
.hole-dot.active{background:#fff}

/* Stepper */
.stepper-group{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);padding:.85rem}
.stepper-label{font-size:.7rem;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);font-weight:600;margin-bottom:.6rem}
.stepper-row{display:grid;grid-template-columns:52px 1fr 52px;align-items:center;gap:.5rem}
.stepper-btn{width:52px;height:52px;border-radius:var(--r-md);background:var(--surface2);border:1.5px solid var(--border);font-size:1.6rem;font-weight:700;display:grid;place-items:center;color:var(--primary);-webkit-user-select:none;user-select:none;transition:background .1s,transform .08s}
.stepper-btn:active{background:var(--primary-l);transform:scale(.93)}
.stepper-val{text-align:center;font-size:2rem;font-weight:700;font-variant-numeric:tabular-nums}
.stepper-sub{text-align:center;font-size:.7rem;color:var(--muted);margin-top:.2rem}

/* Segment picker */
.seg-group{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);padding:.85rem}
.seg-label{font-size:.7rem;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);font-weight:600;margin-bottom:.6rem}
.seg-row{display:flex;gap:.4rem}
.seg-btn{flex:1;min-height:52px;border-radius:var(--r-md);background:var(--surface2);border:1.5px solid var(--border);font-weight:600;font-size:.85rem;-webkit-user-select:none;user-select:none;transition:all .15s}
.seg-btn.active{background:var(--primary);color:var(--inv);border-color:transparent}
.seg-btn.active-warn{background:var(--warn-bg);color:var(--warn);border-color:var(--warn)}
.seg-btn.active-good{background:var(--good-bg);color:var(--good);border-color:var(--good)}
.seg-btn.na-auto{opacity:.55;pointer-events:none}

/* ─── ROUND REVIEW ─────────────────────────────────────────────────────── */
.hole-grid{display:grid;grid-template-columns:repeat(9,1fr);gap:.3rem}
.hole-grid-btn{aspect-ratio:1;border-radius:var(--r-sm);border:none;font-size:.75rem;font-weight:700;font-variant-numeric:tabular-nums;display:grid;place-items:center;cursor:pointer;-webkit-user-select:none;user-select:none;transition:all .12s;color:#fff}
.hole-grid-btn.hg-eagle{background:#b47c16}
.hole-grid-btn.hg-birdie{background:#c0392b}
.hole-grid-btn.hg-par{background:#27ae60}
.hole-grid-btn.hg-bogey{background:#7f8c8d}
.hole-grid-btn.hg-double{background:#1a1a1a}
.hole-grid-btn.hg-worse{background:#000}
.hole-grid-btn:active{transform:scale(.92);opacity:.85}

/* Scorecard table */
.sc-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;border-radius:var(--r-md);border:1px solid var(--border);background:var(--surface)}
table{width:100%;border-collapse:collapse;font-variant-numeric:tabular-nums}
th,td{padding:.55rem .4rem;text-align:center;border-bottom:1px solid var(--divider);font-size:.72rem;white-space:nowrap}
th{font-size:.62rem;text-transform:uppercase;letter-spacing:.05em;color:var(--muted);font-weight:700;background:var(--surface2)}
td:first-child,th:first-child{text-align:left;padding-left:.6rem}
.td-eagle{color:var(--primary);font-weight:800}
.td-birdie{color:var(--good);font-weight:700}
.td-bogey{color:var(--warn)}
.td-dbl{color:var(--bad);font-weight:700}

/* ─── CHART ─────────────────────────────────────────────────────────── */
.chart-wrap{position:relative;height:190px}
.chart-wrap canvas{width:100%!important;height:100%!important}

/* ─── CLUB DISTANCES ─────────────────────────────────────────────────── */
.club-row{display:flex;align-items:center;gap:.6rem;padding:.6rem 0;border-bottom:1px solid var(--divider)}
.club-row:last-child{border-bottom:none}
.club-name{flex:1;font-weight:600}
.club-input{width:72px;text-align:center;padding:.4rem .5rem;border-radius:var(--r-sm);border:1.5px solid var(--border);background:var(--surface2);font-variant-numeric:tabular-nums}
.club-input:focus{border-color:var(--primary);outline:none}
.club-unit{font-size:.75rem;color:var(--muted);width:28px}

/* ─── MISC ─────────────────────────────────────────────────────────── */
.page-title{font-size:1.25rem;font-weight:700}
.page-sub{font-size:.8rem;color:var(--muted);margin-top:.1rem}
.note-box{padding:.7rem .9rem;border-radius:var(--r-md);background:var(--primary-l);border:1px solid color-mix(in oklab,var(--primary) 25%, transparent);font-size:.82rem;color:var(--muted)}
.empty-state{text-align:center;padding:2.5rem 1rem;color:var(--faint);font-size:.9rem}
.divider{height:1px;background:var(--divider);margin:.25rem 0}
.back-btn{display:flex;align-items:center;gap:.3rem;font-size:.85rem;font-weight:600;color:var(--primary);padding:.25rem 0;background:none;border:none;cursor:pointer;-webkit-user-select:none;user-select:none}
.back-btn svg{width:18px;height:18px;stroke-width:2.5}
.badge{display:inline-flex;align-items:center;gap:.3rem;padding:.25rem .6rem;border-radius:var(--r-full);font-size:.7rem;font-weight:600;background:var(--primary-l);color:var(--primary)}
.hidden{display:none!important}
.w600{font-weight:600}
.w700{font-weight:700}
.fs-sm{font-size:.82rem}
.fs-xs{font-size:.72rem}
.col-gap{display:flex;flex-direction:column;gap:.5rem}
.row-gap{display:flex;align-items:center;gap:.5rem}
.mt-sm{margin-top:.5rem}
.mt-md{margin-top:1rem}
.text-muted{color:var(--muted)}
.text-faint{color:var(--faint)}
.accordion-btn{width:100%;text-align:left;padding:.7rem .85rem;border-radius:var(--r-md);background:var(--surface2);border:1px solid var(--border);font-weight:600;font-size:.9rem;display:flex;justify-content:space-between;align-items:center}
.accordion-btn svg{width:16px;height:16px;stroke-width:2.5;transition:transform .2s}
.accordion-btn.open svg{transform:rotate(180deg)}
.accordion-body{padding:.6rem 0 0;display:none}
.accordion-body.open{display:block}
</style>
</head>
<body>
<div id="app">

<!-- TOP BAR -->
<header class="topbar">
  <div class="topbar-brand">
    <div class="logo-wrap" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="2" x2="12" y2="18"/><path d="M12 6c3 1.2 5 2.5 5.5 3.5-2 .6-4 1.3-5.5 2.2"/>
        <ellipse cx="12" cy="20.5" rx="3" ry="1.5"/>
      </svg>
    </div>
    <div>
      <div class="topbar-title">The Stat Caddie</div>
      <div class="topbar-sub" id="topbarSub">Your personal golf stats</div>
    </div>
  </div>
  <button class="icon-btn" id="themeBtn" aria-label="Toggle theme">
    <svg id="themeIconSun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
    <svg id="themeIconMoon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" class="hidden"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
  </button>
</header>

<!-- MAIN CONTENT -->
<main class="main" id="mainContent">

  <!-- ══ DASHBOARD ══ -->
  <section class="view active" id="view-dashboard">
    <div class="card card-hero">
      <div class="list-row" style="margin-bottom:.6rem">
        <div>
          <div class="page-title">Your Stats</div>
          <div class="page-sub" id="dashBadge">Loading…</div>
        </div>
        <button class="btn btn-primary btn-sm" id="newRoundBtn">+ New Round</button>
      </div>
      <div class="stat-grid cols4" id="dashStats"></div>
    </div>

    <div class="card">
      <div class="section-hd"><h2>Score Trend</h2><span class="text-faint fs-xs" id="trendLabel"></span></div>
      <div class="chart-wrap"><canvas id="trendChart"></canvas></div>
    </div>

    <div id="activeRoundBanner" class="hidden">
      <div class="note-box" style="display:flex;justify-content:space-between;align-items:center;gap:.5rem">
        <span id="activeRoundText" class="fs-sm"></span>
        <button class="btn btn-primary btn-sm" id="resumeActiveBtn">Resume</button>
      </div>
    </div>

    <div id="recentRoundsList" class="col-gap">
      <div class="section-hd"><h2>Recent Rounds</h2></div>
    </div>
  </section>

  <!-- ══ COURSES ══ -->
  <section class="view" id="view-courses">
    <div class="list-row">
      <div>
        <div class="page-title">Courses</div>
        <div class="page-sub">5 courses · tap for details</div>
      </div>
    </div>
    <div id="coursesList" class="col-gap"></div>
  </section>

  <!-- ══ COURSE DETAIL ══ -->
  <section class="view" id="view-course-detail">
    <button class="back-btn" id="backFromCourseDetail">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      All Courses
    </button>
    <div class="card card-hero">
      <div class="page-title" id="cdTitle"></div>
      <div class="page-sub" id="cdSub"></div>
      <div class="stat-grid" id="cdStats" style="margin-top:.8rem"></div>
    </div>
    <div class="card">
      <div class="section-hd"><h2>Hole Breakdown</h2></div>
      <div class="sc-wrap">
        <table>
          <thead><tr><th>Hole</th><th>Par</th><th>Avg</th><th>Best</th><th>Putts</th><th>GIR%</th><th>FIR%</th></tr></thead>
          <tbody id="cdHoleRows"></tbody>
        </table>
      </div>
    </div>
    <div id="cdRounds" class="col-gap">
      <div class="section-hd"><h2>Round History</h2><span class="text-faint fs-xs" id="cdRoundCount"></span></div>
    </div>
  </section>

  <!-- ══ HOLE ENTRY ══ -->
  <section class="view" id="view-entry">
    <!-- Hole header with prev/next -->
    <div class="hole-header">
      <div>
        <button class="hole-nav-btn" id="prevHoleBtn" disabled>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
      </div>
      <div class="hole-hd-center">
        <div class="hole-num" id="holeNum">Hole 1</div>
        <div class="hole-par-label" id="holeParLabel">Par 4</div>
      </div>
      <div style="display:flex;justify-content:flex-end">
        <button class="hole-nav-btn" id="nextHoleBtn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
      <div class="hole-progress" id="holeProgress" style="grid-column:1/-1"></div>
    </div>

    <!-- FIR -->
    <div class="seg-group" id="firGroup">
      <div class="seg-label">Fairway in Regulation</div>
      <div class="seg-row" style="flex-wrap:wrap;gap:.35rem">
