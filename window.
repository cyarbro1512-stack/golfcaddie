// SG: Putting — expected putts from distance (feet) for a bogey golfer baseline
// Derived from PGA Tour ShotLink data adjusted ~+15% for bogey golfer
const SG_PUTT_TABLE = {
  3:1.04, 4:1.08, 5:1.13, 6:1.20, 7:1.27, 8:1.34, 9:1.40,
  10:1.47, 12:1.56, 15:1.66, 20:1.78, 25:1.87, 30:1.93,
  40:2.01, 50:2.08
};
function sgPuttExpected(feet){
  const f = parseInt(feet)||10;
  const keys = Object.keys(SG_PUTT_TABLE).map(Number).sort((a,b)=>a-b);
  // interpolate
  for(let i=0;i<keys.length-1;i++){
    if(f>=keys[i] && f<=keys[i+1]){
      const t=(f-keys[i])/(keys[i+1]-keys[i]);
      return SG_PUTT_TABLE[keys[i]]*(1-t)+SG_PUTT_TABLE[keys[i+1]]*t;
    }
  }
  if(f<=keys[0]) return SG_PUTT_TABLE[keys[0]];
  return SG_PUTT_TABLE[keys[keys.length-1]];
}

// SG: Putting for a round — sum over all holes, adjusted for baseline level
function sgPuttingRound(round){
  const bl = SG_BASELINES[_sgBaseline] || SG_BASELINES[18];
  return round.holes.reduce((sum,h)=>{
    const exp = sgPuttExpected(h.firstPuttDist||10) * bl.puttMult;
    return sum + (exp - h.putts);
  },0);
}

// ── Handicap Baselines ────────────────────────────────────────────────
// Each level: { score (over par 72), gir (greens/round), fir (fairways/14), putt_mult }
// putt_mult scales expected putts up/down vs tour (1.0 = same as table, 1.15 = 15% more)
const SG_BASELINES = {
  scratch: { label:'Scratch',   scoreOver:0,  gir:11.0, fir:9.5,  puttMult:1.02 },
  5:       { label:'5 hdcp',    scoreOver:5,  gir: 9.0, fir: 8.5, puttMult:1.05 },
  10:      { label:'10 hdcp',   scoreOver:10, gir: 7.0, fir: 7.0, puttMult:1.10 },
  18:      { label:'18 hdcp',   scoreOver:18, gir: 4.5, fir: 5.0, puttMult:1.15 },
  25:      { label:'25 hdcp',   scoreOver:25, gir: 2.5, fir: 3.5, puttMult:1.20 }
};
let _sgBaseline = '18'; // default: bogey golfer

// SG: Approach — based on GIR hit rate vs selected baseline
function sgApproachRound(round){
  const bl = SG_BASELINES[_sgBaseline] || SG_BASELINES[18];
  const girHit = round.holes.filter(h=>h.gir==='yes'||h.gir==='chip').length;
  return (girHit - bl.gir) * 0.6;
}

// SG: Off the Tee — based on FIR hit rate vs selected baseline
function sgDrivingRound(round, course){
  const bl = SG_BASELINES[_sgBaseline] || SG_BASELINES[18];
  const pars = course.holes;
  const opp = pars.filter(p=>p>3).length;
  if(!opp) return 0;
  const firHit = round.holes.filter((h,i)=>pars[i]>3&&h.fir==='yes').length;
  const scaled = firHit * (14/opp);
  return (scaled - bl.fir) * 0.4;
}

// SG: Short Game — inferred from penalty strokes and missed GIR recovery
// Captures up-and-down situations. When GIR missed + putts <= 2 = good scramble
// When GIR missed + putts > 2 or penalties > 0 = strokes lost
function sgShortGameRound(round){
  let sg = 0;
  round.holes.forEach(h=>{
    const girMiss = h.gir!=='yes'&&h.gir!=='chip';
    if(girMiss){
      // scramble par or better = gained, 3+ putts from miss = lost
      if(h.putts<=1) sg += 0.5;       // chip in / 1 putt = great scramble
      else if(h.putts===2) sg += 0.0; // standard scramble = neutral
      else sg -= 0.5;                 // 3-putt from off green = lost
    }
    // penalties always cost
    sg -= (h.penalties||0) * 0.8;
  });
  return sg;
}

// SG: Score (overall) — actual score vs selected handicap baseline
function sgScoreRound(round, course){
  const bl = SG_BASELINES[_sgBaseline] || SG_BASELINES[18];
  const par = course.holes.reduce((s,p)=>s+p,0);
  const t = roundTotals(round);
  const baseline = par + bl.scoreOver;
  return baseline - t.total; // positive = better than baseline
}

function calcSGSummary(rounds){
  if(!rounds.length) return null;
  const categories = {
    driving:   { label:'Off the Tee', values:[], color:'#2980b9', icon:'🏌️' },
    approach:  { label:'Approach',    values:[], color:'#27ae60', icon:'🎯' },
    shortGame: { label:'Short Game',  values:[], color:'#e67e22', icon:'⛳' },
    putting:   { label:'Putting',     values:[], color:'#8e44ad', icon:'🏒' },
    overall:   { label:'Scoring',     values:[], color:'#c0392b', icon:'📊' }
  };
  rounds.forEach(r=>{
    const c = courseById(r.courseId);
    if(!c) return;
    categories.driving.values.push(sgDrivingRound(r,c));
    categories.approach.values.push(sgApproachRound(r));
    categories.shortGame.values.push(sgShortGameRound(r));
    categories.putting.values.push(sgPuttingRound(r));
    categories.overall.values.push(sgScoreRound(r,c));
  });
  // average each category
  const result = {};
  Object.entries(categories).forEach(([k,v])=>{
    const a = v.values.reduce((s,x)=>s+x,0)/v.values.length;
    result[k] = { ...v, avg: +a.toFixed(2) };
  });
  return result;
}

function renderPerformance(){
  const completed = sortedRounds().filter(r=>r.status==='complete');
  const sgEmpty = document.getElementById('sgEmpty');
  const sgContent = document.getElementById('sgContent');
  if(completed.length < 2){
    sgEmpty.style.display='';
    sgContent.style.display='none';
    return;
  }
  sgEmpty.style.display='none';
  sgContent.style.display='';

  const sg = calcSGSummary(completed);
  if(!sg) return;

  // ── Radar Chart ──────────────────────────────────────────────────────
  const radar = document.getElementById('sgRadar');
  const cats = ['driving','approach','shortGame','putting','overall'];
  const labels = ['Off Tee','Approach','Short Game','Putting','Scoring'];
  const cx=110, cy=100, r=72;
  const angles = cats.map((_,i)=> (Math.PI*2*i/cats.length) - Math.PI/2);
  // normalize values to 0-1 range for radar (clamp -8 to +8)
  const norm = v => Math.max(0, Math.min(1, (v+8)/16));

  // grid rings
  let svgHTML = '';
  [0.25,0.5,0.75,1].forEach(t=>{
    const pts = angles.map(a=>`${cx+r*t*Math.cos(a)},${cy+r*t*Math.sin(a)}`).join(' ');
    svgHTML += `<polygon points="${pts}" fill="none" stroke="var(--border)" stroke-width="${t===1?1.5:.7}" opacity=".6"/>`;
  });
  // spokes
  angles.forEach(a=>{
    svgHTML += `<line x1="${cx}" y1="${cy}" x2="${cx+r*Math.cos(a)}" y2="${cy+r*Math.sin(a)}" stroke="var(--border)" stroke-width=".7" opacity=".5"/>`;
  });
  // data polygon
  const dataPoints = cats.map((k,i)=>{
    const n = norm(sg[k].avg);
    return `${cx+r*n*Math.cos(angles[i])},${cy+r*n*Math.sin(angles[i])}`;
  }).join(' ');
  svgHTML += `<polygon points="${dataPoints}" fill="var(--primary)" fill-opacity=".22" stroke="var(--primary)" stroke-width="2"/>`;
  // dots
  cats.forEach((k,i)=>{
    const n=norm(sg[k].avg);
    svgHTML += `<circle cx="${cx+r*n*Math.cos(angles[i])}" cy="${cy+r*n*Math.sin(angles[i])}" r="4" fill="var(--primary)"/>`;
  });
  // labels
  labels.forEach((lbl,i)=>{
    const lx = cx + (r+14)*Math.cos(angles[i]);
    const ly = cy + (r+14)*Math.sin(angles[i]);
    const anchor = Math.cos(angles[i])>0.1?'start':Math.cos(angles[i])<-0.1?'end':'middle';
    svgHTML += `<text x="${lx}" y="${ly}" text-anchor="${anchor}" dominant-baseline="middle" font-size="9" fill="var(--text2)" font-family="inherit">${lbl}</text>`;
  });
  // center label
  svgHTML += `<text x="${cx}" y="${cy}" text-anchor="middle" dominant-baseline="middle" font-size="8" fill="var(--text2)" opacity=".6">baseline</text>`;
  radar.innerHTML = svgHTML;

  // ── SG Bars ───────────────────────────────────────────────────────────
  const barsEl = document.getElementById('sgBars');
  barsEl.innerHTML = cats.map(k=>{
    const d = sg[k];
    const val = d.avg;
    const positive = val >= 0;
    const barPct = Math.min(100, Math.abs(val)/8*100);
    const sign = positive?'+':'';
    const color = positive ? 'var(--primary)' : '#c0392b';
    const label = positive ? 'gaining' : 'losing';
    return `<div>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.2rem">
        <span style="font-size:.78rem;font-weight:600">${d.icon} ${d.label}</span>
        <span style="font-size:.78rem;font-weight:700;color:${color}">${sign}${val.toFixed(2)} SG</span>
      </div>
      <div style="height:7px;background:var(--surface2);border-radius:4px;overflow:hidden">
        <div style="height:100%;width:${barPct}%;background:${color};border-radius:4px;transition:width .4s ease;${!positive?'margin-left:auto':''}"></div>
      </div>
      <div style="font-size:.68rem;color:var(--text2);margin-top:.15rem">${Math.abs(val).toFixed(2)} strokes ${label} per round vs. bogey golfer baseline</div>
    </div>`;
  }).join('');

  // ── Callout: weakest area ─────────────────────────────────────────────
  const worst = cats.reduce((w,k)=> sg[k].avg < sg[w].avg ? k : w, cats[0]);
  const best  = cats.reduce((b,k)=> sg[k].avg > sg[b].avg ? k : b, cats[0]);
  const worstD = sg[worst];
  const bestD  = sg[best];
  const tips = {
    driving:   'Focus on keeping drives in the fairway — even a shorter straight drive saves strokes over a long wayward one.',
    approach:  'Work on consistent ball-striking into greens. More GIRs = fewer scramble situations and easier pars.',
    shortGame: 'Practice your chip and pitch from 10-30 yards. Getting up-and-down more often is the fastest way to lower scores.',
    putting:   'Lag putting from 20+ feet is where most strokes are lost. Drill distance control to eliminate 3-putts.',
    overall:   'Your scoring relative to par is the combined result of all categories — target the weakest area above.'
  };
  document.getElementById('sgCallout').innerHTML =
    `<div style="font-weight:700;margin-bottom:.3rem">📍 Biggest opportunity: ${worstD.icon} ${worstD.label}</div>
     <div style="color:var(--text2)">${tips[worst]}</div>
     <div style="margin-top:.5rem;font-size:.72rem;color:var(--text2);border-top:1px solid var(--border);padding-top:.4rem">
       ✅ Strength: ${bestD.icon} ${bestD.label} (+${bestD.avg.toFixed(2)} SG avg) &nbsp;·&nbsp;
       <span style="opacity:.7">Baseline = ${SG_BASELINES[_sgBaseline]?.label||'18 hdcp'} golfer (${72+(SG_BASELINES[_sgBaseline]?.scoreOver||18)} on par 72)</span>
     </div>`;
}


