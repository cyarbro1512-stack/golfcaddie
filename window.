function bindRoundActions(el){
  el.querySelectorAll('[data-view-rnd]').forEach(b=>b.onclick=(e)=>{
    e.stopPropagation();
    openRoundSummary(b.dataset.viewRnd, 'rounds');
  });
  el.querySelectorAll('[data-edit-rnd]').forEach(b=>b.onclick=(e)=>{
    e.stopPropagation();
    resumeRound(b.dataset.editRnd);
  });
  el.querySelectorAll('[data-del-rnd]').forEach(b=>{
    b._delPending = false;
    b.onclick=(e)=>{
      e.stopPropagation();
      if(!b._delPending){
        b._delPending = true;
        b.textContent = 'Confirm?';
        b.style.background = '#c0392b';
        b.style.color = '#fff';
        setTimeout(()=>{
          if(b._delPending){ b._delPending=false; b.textContent='Delete'; b.style.background=''; b.style.color=''; }
        }, 3000);
      } else {
        (async ()=>{
          const roundId = b.dataset.delRnd;
          const ok = await deleteRoundFromSupabase(roundId);
          if(!ok) return;
          const s = getStore();
          s.rounds = s.rounds.filter(r=>r.id!==roundId);
          saveStore(s);
          renderAll();
        })();
      }
    };
  });
  el.querySelectorAll('.list-item').forEach(item=>item.onclick=()=>{
    const vid = item.querySelector('[data-view-rnd]')?.dataset.viewRnd;
    if(vid) openRoundSummary(vid,'rounds');
  });
}

